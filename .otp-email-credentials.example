# Copy this file to .otp-email-credentials (gitignored)
# and fill with your real values.

OTP_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
OTP_SMTP_PORT=465
OTP_SMTP_SECURE=true
OTP_SMTP_USERNAME=
OTP_SMTP_PASSWORD=
OTP_FROM_EMAIL=
OTP_FROM_NAME=VTC Attendance
OTP_EMAIL_SUBJECT=Your verification code
OTP_APP_NAME=ProvePresent

# Optional: Restrict authentication to specific email domains (comma-separated)
# Leave empty or comment out for no restriction
ALLOWED_EMAIL_DOMAINS=vtc.edu.hk,stu.vtc.edu.hk

# Optional: Organization name for UI display
ORGANIZATION_NAME=VTC

