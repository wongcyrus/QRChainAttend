{
  "name": "@prove-present/backend",
  "version": "1.0.0",
  "description": "Azure Functions backend for ProvePresent System",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "func start",
    "test": "jest",
    "test:unit": "jest --testPathPattern=\\.test\\.ts$",
    "test:property": "jest --testPathPattern=\\.property\\.test\\.ts$",
    "test:smtp": "npm run build && node dist/src/scripts/testOtpSmtp.js",
    "test:smtp:send": "npm run build && node dist/src/scripts/testOtpSmtp.js --send",
    "lint": "eslint src --ext .ts",
    "prestart": "npm run build",
    "predeploy": "npm run build"
  },
  "dependencies": {
    "@azure/ai-agents": "^1.0.0",
    "@azure/ai-projects": "^1.0.0-beta.11",
    "@azure/data-tables": "^13.3.2",
    "@azure/functions": "^4.11.1",
    "@azure/identity": "^4.13.0",
    "@azure/storage-blob": "^12.30.0",
    "@azure/web-pubsub": "^1.2.0",
    "durable-functions": "^3.3.0",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}
